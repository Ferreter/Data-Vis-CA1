      <aliases enabled='yes' />
      <column caption='Match Outcome' datatype='string' name='[Calculation_2639696805163008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Full Time Result] = &quot;H&quot; THEN &quot;Home Win&quot;&#13;&#10;ELSEIF [Full Time Result] = &quot;A&quot; THEN &quot;Away Win&quot;&#13;&#10;ELSE &quot;Draw&quot;&#13;&#10;END' />
      </column>
      <column caption='Home Win' datatype='integer' name='[Calculation_2639697107775489]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Full Time Result] = &quot;H&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Away Win' datatype='integer' name='[Calculation_2639697107976194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Full Time Result] = &quot;A&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Goals Scored' datatype='integer' name='[Calculation_2639697110454276]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;Home Team&quot;&#13;&#10;THEN [Full Time Home Goals]&#13;&#10;ELSE [Full Time Away Goals]&#13;&#10;END' />
      </column>
      <column caption='Shots' datatype='integer' name='[Calculation_2639697111588869]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;Home Team&quot;&#13;&#10;THEN [Home Team Shots]&#13;&#10;ELSE [Away Team Shots]&#13;&#10;END' />
      </column>
      <column caption='Conversion Rate' datatype='real' name='[Calculation_2639697111691270]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_2639697110454276]) / SUM([Calculation_2639697111588869])' />
      </column>
      <column caption='Outcome' datatype='string' name='[Calculation_2639697124421640]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Full Time Result] = &quot;H&quot; THEN &quot;Home Win&quot;&#13;&#10;ELSEIF [Full Time Result] = &quot;A&quot; THEN &quot;Away Win&quot;&#13;&#10;ELSE &quot;Draw&quot;&#13;&#10;END' />
      </column>
      <column caption='Average Fulltime Home Goals' datatype='real' name='[Calculation_2639697127821321]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Full Time Home Goals])' />
      </column>
      <column caption='Average Fulltime Away Goals' datatype='real' name='[Calculation_2639697127972874]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Full Time Away Goals])' />
      </column>
      <column caption='Home Team Cards' datatype='integer' name='[Calculation_2639697135894539]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Home Team Yellow Cards] + [Home Team Red Cards]' />
      </column>
      <column caption='Away Team Cards' datatype='integer' name='[Calculation_2639697136533516]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Away Team Yellow Cards] + [Away Team Red Cards]' />
      </column>
      <column caption='Percent of Outcome' datatype='real' name='[Calculation_2639697147256845]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Full Time Result]) / TOTAL(COUNT([Full Time Result]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
