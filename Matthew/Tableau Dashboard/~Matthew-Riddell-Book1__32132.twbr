        <view>
          <datasources>
            <datasource caption='cleaned_season_data' name='federated.0c7goyy1e17x7s13vld4s1dxa4ke' />
          </datasources>
          <datasource-dependencies datasource='federated.0c7goyy1e17x7s13vld4s1dxa4ke'>
            <column datatype='integer' name='[Away Team Shots]' role='measure' type='quantitative' />
            <column caption='Goals Scored' datatype='integer' name='[Calculation_2639697110454276]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;Home Team&quot;&#13;&#10;THEN [Full Time Home Goals]&#13;&#10;ELSE [Full Time Away Goals]&#13;&#10;END' />
